# ============================================================
# Apex UGR — Environment Variables
# Copy this file to .env and fill in your real values.
# ============================================================

# --- SUPABASE (Required) ---
# Get these from: https://supabase.com → your project → Settings → API
EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# --- eBay Motors API (Phase 4: Marketplace) ---
# Get from: https://developer.ebay.com
EXPO_PUBLIC_EBAY_APP_ID=YOUR_EBAY_APP_ID

# --- NHTSA Vehicle API (Free, no key needed) ---
# Used for VIN decoding and fitment data
# Base URL: https://vpic.nhtsa.dot.gov/api/

# --- Stripe (Phase 4: Payments) ---
# Get from: https://dashboard.stripe.com
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_YOUR_KEY

# --- Expo Push Notifications (Phase 9) ---
# Configured automatically via expo-notifications
